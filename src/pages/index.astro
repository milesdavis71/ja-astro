---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import NewsCards from '../components/NewsCards.astro'
import HighlightedActivities from '../components/HighlightedActivities.astro'

export const frontmatter = {
  title: '',
  metaTitle: 'Főoldal',
  showPageTitle: false,
  contentClass: 'pt-0',
}

const postModules = import.meta.glob('../content/news/*.mdx', { eager: true })
const newsPosts = Object.entries(postModules)
  .map(([file, mod]) => ({ file, ...(mod as any) }))
  .filter((post) => post.frontmatter?.draft !== true)

const featuredNews = newsPosts
  .map((post, index) => {
    const slug =
      post.file
        ?.split('/')
        .pop()
        ?.replace(/\.mdx?$/, '') || `news-${index}`

    return {
      id: index + 1,
      title: post.frontmatter?.title || 'Cím nélkül',
      slug,
      date: post.frontmatter?.date
        ? new Date(post.frontmatter.date).toISOString().split('T')[0]
        : '2026-02-23',
      excerpt: post.frontmatter?.excerpt || '',
      image: post.frontmatter?.thumbnail || '/images/ja-logo-magenta-blue-fekvo-for-dark-bg.svg',
      category: 'Hír',
    }
  })
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3)
---

<DefaultLayout {frontmatter}>
  <HighlightedActivities featured onlyFirst />

  <section id="news" class="bg-gray-50 py-4">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 id="hirek" class="text-center">Hírek</h2>
      <NewsCards items={featuredNews} />
    </div>
  </section>

  <HighlightedActivities slot="rightSidebar" sidebar skipFirst />
</DefaultLayout>
