---
const { frontmatter } = Astro.props
const contentClass = frontmatter?.contentClass || ''
---
<main class={`flex-1 w-full ${contentClass}`}>
  <!-- Page Title -->
  {frontmatter?.title && frontmatter?.showPageTitle !== false && !frontmatter?.hidePageTitle && (
    <header class="mb-8">
      <h1 class="text-xl font-bold border-b border-gray-200 pb-3 mb-4">
        {frontmatter.title}
      </h1>
      {frontmatter?.description && (
        <p class="text-gray-600">{frontmatter.description}</p>
      )}
    </header>
  )}
  <slot />
</main>
