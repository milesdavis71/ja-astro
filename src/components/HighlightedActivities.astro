---
import Button from './Button.astro'
import highlightedActivitiesData from '../data/kiemelt-tevekenysegek.yml'

type HighlightedActivity = {
  id?: string
  title?: string
  description?: string
  lead?: string
  image?: string
  imageAlt?: string
  link?: string
  href?: string
  ctaLabel?: string
}

interface Props {
  sidebar?: boolean
  featured?: boolean
  onlyFirst?: boolean
  skipFirst?: boolean
}

const { sidebar = false, featured = false, onlyFirst = false, skipFirst = false } = Astro.props

const dataSource = Array.isArray(highlightedActivitiesData)
  ? highlightedActivitiesData
  : highlightedActivitiesData?.items

const allActivities = (dataSource ?? []).map((item: HighlightedActivity, index: number) => ({
  id: item.id ?? `kiemelt-tevekenyseg-${index + 1}`,
  title: item.title ?? 'Juniorakadémia tevékenység',
  description: item.description ?? item.lead ?? '',
  image: item.image ? `/images/kiemelt-tevekenysegek/${item.image}` : null,
  imageAlt: item.imageAlt ?? item.title ?? 'Juniorakadémia tevékenység',
  link: item.link ?? item.href ?? '#',
  ctaLabel: item.ctaLabel ?? 'Tovább',
}))

const highlightedActivities = onlyFirst
  ? allActivities.slice(0, 1)
  : skipFirst
    ? allActivities.slice(1)
    : allActivities

const sectionClasses = sidebar ? 'bg-white' : 'bg-white py-2 sm:py-4'
const outerClasses = sidebar || featured ? '' : 'mx-auto max-w-7xl px-4 sm:px-6 lg:px-8'
const frameClasses = sidebar
  ? 'bg-white p-0'
  : featured
    ? 'rounded-md border border-slate-300 bg-white p-3'
    : 'rounded-md border border-slate-300 bg-white p-2 sm:p-3'
const gridClasses = sidebar ? 'grid grid-cols-1 gap-4' : 'grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3'
---

{
  highlightedActivities.length > 0 &&
    (featured ? (
      <section id="kiemelt-tevekenyseg-kiemelt" class="bg-white py-4">
        <div class={frameClasses}>
          {highlightedActivities.map((activity) => (
            <article class="featured-activity">
              <div class="featured-activity__grid">
                <div class="featured-activity__media">
                  {activity.image ? (
                    <div class="featured-activity__image-frame">
                      <img
                        src={activity.image}
                        alt={activity.imageAlt}
                        class="featured-activity__image"
                        loading="lazy"
                      />
                    </div>
                  ) : (
                    <div class="featured-activity__image-frame featured-activity__image-placeholder">
                      Kép: <code>{'/public/images/kiemelt-tevekenysegek/'}</code>
                    </div>
                  )}
                </div>

                <div class="featured-activity__content">
                  <h2 class="featured-activity__title">{activity.title}</h2>
                  {activity.description && (
                    <p class="featured-activity__description">{activity.description}</p>
                  )}

                  <div class="featured-activity__cta">
                    <Button link={activity.link} text={activity.ctaLabel} />
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <section id="kiemelt-tevekenysegek" class={sectionClasses}>
        <div class={outerClasses}>
          <div class={frameClasses}>
            <div class={`mb-5 ${sidebar ? '' : 'text-center'}`}>
              <h2 class={`mb-0 ${sidebar ? 'text-left text-lg text-[color:var(--primary-color)]' : 'text-xl'}`}>
                Aktuális pályázataink, ösztöndíjaink, programjaink
              </h2>
            </div>

            <div class={gridClasses}>
              {highlightedActivities.map((activity) => (
                <a href={activity.link} class="activity-card-link group block">
                  <article class="activity-card overflow-hidden rounded-md border border-slate-200 bg-white transition-shadow duration-200">
                    <div class="activity-card__top bg-blue-100">
                      <h3 class="activity-card__title">{activity.title}</h3>
                    </div>

                    <div class="activity-card__body">
                      {activity.image ? (
                        <div class="activity-card__image-frame">
                          <img
                            src={activity.image}
                            alt={activity.imageAlt}
                            class="activity-card__image"
                            loading="lazy"
                          />
                        </div>
                      ) : (
                        <div class="activity-card__image-frame activity-card__image-placeholder">
                          Kép: <code>{'/public/images/kiemelt-tevekenysegek/'}</code>
                        </div>
                      )}

                      {activity.description && (
                        <p class="activity-card__description">{activity.description}</p>
                      )}

                      <span class="activity-card__cta">{activity.ctaLabel}</span>
                    </div>
                  </article>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    ))
}

<style>
  .activity-card-link {
    height: 100%;
    text-decoration: none;
  }

  .activity-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .group:hover .activity-card,
  .group:focus-visible .activity-card {
    box-shadow: 0 4px 8px rgb(from var(--secondary-color) r g b / 22%);
  }

  .activity-card__top {
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid rgb(from var(--primary-color) r g b / 12%);
  }

  .activity-card__title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
    text-align: left;
    color: var(--primary-color);
  }

  .activity-card__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
    padding: 0.85rem;
    align-items: stretch;
  }

  .activity-card__image-frame,
  .featured-activity__image-frame {
    width: 100%;
    border: 1px solid rgb(203 213 225);
    border-radius: 0.5rem;
    padding: 0.2rem;
    background: white;
  }

  .activity-card__image,
  .featured-activity__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 0.35rem;
  }

  .activity-card__image-placeholder,
  .featured-activity__image-placeholder {
    min-height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgb(100 116 139);
    background: rgb(248 250 252);
  }

  .activity-card__description {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    text-align: left;
    color: rgb(51 65 85);
  }

  .activity-card__cta {
    margin-top: auto;
    align-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 0;
    padding: 0.45rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: white;
    background-color: var(--secondary-color);
    transition:
      background-color 150ms ease,
      box-shadow 150ms ease;
  }

  .group:hover .activity-card__cta,
  .group:focus-visible .activity-card__cta {
    background-color: var(--primary-color);
  }

  .featured-activity__grid {
    display: grid;
    gap: 1rem;
  }

  .featured-activity__content {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1rem;
  }

  .featured-activity__title {
    margin: 0;
    font-size: 1.35rem;
    line-height: 1.3;
    color: var(--primary-color);
    text-align: left;
  }

  .featured-activity__description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: rgb(51 65 85);
    text-align: left;
  }

  .featured-activity__cta {
    margin-top: auto;
    text-align: center;
  }

  .featured-activity__cta :global(.btn) {
    background-color: var(--secondary-color);
    color: white !important;
  }

  .featured-activity__cta :global(.btn:hover) {
    background-color: var(--primary-color);
  }

  @media (min-width: 768px) {
    .featured-activity__grid {
      grid-template-columns: 2fr 3fr;
      align-items: start;
    }
  }
</style>
